# ===========================================
# Personal AI Concierge - Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# App
DEBUG=false

# Database (Neon / Supabase / any PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/concierge

# Redis (Upstash / any Redis)
REDIS_URL=redis://default:password@host:6379

# WhatsApp Meta Cloud API
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_TOKEN=your-meta-api-token
WHATSAPP_APP_SECRET=your-app-secret

# Anthropic (Claude Haiku - cheapest model)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001

# OpenAI Embeddings
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# Qdrant Cloud
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Admin
ADMIN_API_KEY=your-admin-api-key
JWT_SECRET=your-jwt-secret-change-in-production

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
